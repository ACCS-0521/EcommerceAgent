{
  "version": "1.0",
  "effectiveDate": "2026-01-01",

  "sevenDaysReturn": true,

  "sevenDaysReturnDescription": "商品签收后7天内，在不影响二次销售的情况下支持无理由退货。",

  "qualityProblemShippingFee": {
    "sellerPays": true,
    "description": "因商品质量问题产生的退换货运费由商家承担。"
  },

  "nonQualityProblemShippingFee": {
    "sellerPays": false,
    "description": "非质量问题退货运费由买家承担。"
  },

  "refundTime": {
    "minDays": 1,
    "maxDays": 3,
    "description": "退款审核通过后1-3个工作日原路退回。"
  },

  "openedProductReturn": {
    "allowed": false,
    "description": "影响二次销售的商品不支持无理由退货。"
  },

  "exchangePolicy": {
    "supported": true,
    "description": "符合售后条件的商品支持换货服务。"
  },

  "warrantyPolicy": {
    "supported": true,
    "defaultWarrantyMonths": 12,
    "description": "数码类商品默认提供12个月质保服务。"
  },

  "nonReturnableCategories": [
    "定制商品",
    "虚拟商品",
    "已激活软件",
    "影响二次销售商品"
  ],

  "refundReasons": [
    {
      "code": "QUALITY_ISSUE",
      "name": "商品质量问题",
      "allowReturn": true,
      "allowExchange": true
    },
    {
      "code": "DAMAGED",
      "name": "运输损坏",
      "allowReturn": true,
      "allowExchange": true
    },
    {
      "code": "WRONG_ITEM",
      "name": "发错商品",
      "allowReturn": true,
      "allowExchange": true
    },
    {
      "code": "PERSONAL_REASON",
      "name": "个人原因",
      "allowReturn": true,
      "allowExchange": false
    }
  ],

  "artificialService": {
    "enabled": true,
    "serviceId": "service001",
    "serviceHours": "09:00-21:00"
  }
}